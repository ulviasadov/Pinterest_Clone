@model PinterestClone.Models.Board
@{
    var pins = ViewBag.Pins as List<PinterestClone.Models.Pin>;
}

<h2>@Model.Title</h2>
@if (pins != null && pins.Any())
{
    <div class="row">
        @foreach (var pin in pins)
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    <img src="@pin.ImagePath" class="card-img-top" alt="@pin.Title" style="height:200px;object-fit:cover;">
                    <div class="card-body">
                        <h5 class="card-title">@pin.Title</h5>
                        <p class="card-text">@pin.Description</p>
                        <a asp-controller="Board" asp-action="Detail" asp-route-id="@pin.Id" class="btn btn-primary">View Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">No pins in this board.</div>
}
