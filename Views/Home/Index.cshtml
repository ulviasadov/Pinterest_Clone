@{
    ViewData["Title"] = "Home Page";
    var search = ViewBag.Search as string;
    var pins = ViewBag.Pins as List<PinterestClone.Models.Pin>;
    var users = ViewBag.Users as List<PinterestClone.Models.User>;
    var followingPins = ViewBag.FollowingPins as List<PinterestClone.Models.Pin>;
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-8 offset-md-2">
            <form method="get" class="d-flex">
                <input type="text" name="search" class="form-control me-2" placeholder="Search pins or accounts..."
                    value="@ViewBag.Search" />
                <button type="submit" class="btn btn-primary">Search</button>
            </form>
            <div class="mt-2">
                <a href="?search=@(ViewBag.Search ?? "")&filter=pins"
                    class="btn btn-outline-secondary @(ViewBag.Filter == " pins" ? "active" : "" )">Pins</a>
                <a href="?search=@(ViewBag.Search ?? "")&filter=accounts"
                    class="btn btn-outline-secondary @(ViewBag.Filter == " accounts" ? "active" : "" )">Accounts</a>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-md-8 offset-md-2">
            @if (!string.IsNullOrWhiteSpace(search))
            {
            <h2>Pins</h2>
            @if (pins != null && pins.Any())
            {
            <div class="row">
                @foreach (var pin in pins)
                {
                <div class="col-md-4 mb-3">
                    <div class="card">
                        <img src="@pin.ImagePath" class="card-img-top" alt="@pin.Title" style="height:150px;object-fit:cover;">
                        <div class="card-body">
                            <h5 class="card-title">@pin.Title</h5>
                            <p class="card-text">@pin.Description</p>
                            <p class="text-muted">By @pin.User?.Name</p>
                            <a asp-controller="Pin" asp-action="Details" asp-route-id="@pin.Id" class="btn btn-primary">Details</a>
                        </div>
                    </div>
                </div>
                }
            </div>
            }
            else
            {
            <div class="alert alert-info">No pins found.</div>
            }

            <h2>Accounts</h2>
            @if (users != null && users.Any())
            {
            <ul class="list-group mb-3">
                @foreach (var user in users)
                {
                    var profileImage = !string.IsNullOrWhiteSpace(user.ProfileImagePath)
                        ? user.ProfileImagePath
                        : Url.Content("~/images/PP.jpg");
                    <li class="list-group-item d-flex align-items-center">
                        <img src="@profileImage"
                             alt="Profile Photo"
                             class="rounded-circle me-2"
                             style="width:40px; height:40px; object-fit:cover;" />
                        <a asp-controller="User" asp-action="Profile" asp-route-id="@user.Id" class="fw-bold text-decoration-none me-2">
                            @user.Name
                        </a>
                        <span class="text-muted">(@user.Email)</span>
                    </li>
                }
            </ul>
            }
            else
            {
            <div class="alert alert-info">No accounts found.</div>
            }
            }
            else
            {
            @if (followingPins != null && followingPins.Any())
            {
                <h2>Pins from users you follow</h2>
                <div class="row">
                    @foreach (var pin in followingPins)
                    {
                    <div class="col-md-4 mb-3">
                        <div class="card">
                            <img src="@pin.ImagePath" class="card-img-top" alt="@pin.Title" style="height:150px;object-fit:cover;">
                            <div class="card-body">
                                <h5 class="card-title">@pin.Title</h5>
                                <p class="card-text">@pin.Description</p>
                                <p class="text-muted">By @pin.User?.Name</p>
                                <a asp-controller="Pin" asp-action="Details" asp-route-id="@pin.Id" class="btn btn-primary">Details</a>
                            </div>
                        </div>
                    </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">No pins from users you follow.</div>
            }
            }
        </div>
    </div>
</div>